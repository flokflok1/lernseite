# LernsystemX Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
API_GATEWAY_MAX_BODY_SIZE=10485760

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/lernsystemx_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lernsystemx_dev
DB_USER=username
DB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# AI Integration - Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# AI Integration - OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Translation - DeepL
DEEPL_API_KEY=your-deepl-api-key

# Payment Processing - Stripe
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Premium Model Configuration
PREMIUM_PRICE_MONTHLY=14.99
PREMIUM_PRICE_YEARLY=129.99
PREMIUM_TOKENS_MONTHLY=10000

# Token Pricing (EUR per 1000 tokens)
TOKEN_PRICE_5K=1.99
TOKEN_PRICE_20K=6.99
TOKEN_PRICE_50K=14.99
TOKEN_PRICE_100K=24.99

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@lernsystemx.com

# CORS Configuration (Development: * allows all origins)
CORS_ORIGINS=*

# SocketIO Configuration
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/3
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/4
RATELIMIT_DEFAULT=200 per hour

# File Upload Configuration
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,docx,pptx,jpg,jpeg,png,gif

# Frontend URL
FRONTEND_URL=http://localhost:5173

# LiveRoom Configuration (WebRTC)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=username
TURN_PASSWORD=password

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/lernsystemx.log

# Session Configuration
SESSION_TYPE=redis
SESSION_PERMANENT=False
SESSION_USE_SIGNER=True
SESSION_REDIS_URL=redis://localhost:6379/5
