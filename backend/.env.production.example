# LernsystemX Production Environment Configuration
# Copy this file to .env and fill in your values
# This is a template for production environments with stricter security

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY
DEBUG=False
API_GATEWAY_MAX_BODY_SIZE=10485760

# Database Configuration (PostgreSQL)
# NOTE: Configured during Setup Wizard - DO NOT UNCOMMENT MANUALLY
# DATABASE_URL=postgresql://username:password@localhost:5432/lernsystemx_prod
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lernsystemx_prod
# DB_USER=username
# DB_PASSWORD=password

# Redis Configuration
# NOTE: Configured during Setup Wizard - DO NOT UNCOMMENT MANUALLY
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# Celery Configuration
# NOTE: Configured during Setup Wizard - DO NOT UNCOMMENT MANUALLY
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Configuration
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_JWT_SECRET
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# AI Integration - Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# AI Integration - OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Translation - DeepL
DEEPL_API_KEY=your-deepl-api-key

# Payment Processing - Stripe
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Premium Model Configuration
PREMIUM_PRICE_MONTHLY=14.99
PREMIUM_PRICE_YEARLY=129.99
PREMIUM_TOKENS_MONTHLY=10000

# Token Pricing (EUR per 1000 tokens)
TOKEN_PRICE_5K=1.99
TOKEN_PRICE_20K=6.99
TOKEN_PRICE_50K=14.99
TOKEN_PRICE_100K=24.99

# Email Configuration (Legacy Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@lernsystemx.com

# Email Service Configuration (New Template-based Email Utility)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SENDER_EMAIL=noreply@lernsystemx.com
SENDER_NAME=LernSystemX
EMAIL_PROVIDER=smtp
# Admin email for B2B contact notifications
ADMIN_EMAIL=admin@lernsystemx.com

# CORS Configuration (Production: Specify allowed origins)
CORS_ORIGINS=https://lernsystemx.com,https://www.lernsystemx.com

# SocketIO Configuration
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/3
SOCKETIO_CORS_ALLOWED_ORIGINS=https://lernsystemx.com,https://www.lernsystemx.com

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/4
RATELIMIT_DEFAULT=200 per hour

# File Upload Configuration
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,docx,pptx,jpg,jpeg,png,gif

# Frontend URL
FRONTEND_URL=https://lernsystemx.com

# LiveRoom Configuration (WebRTC)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=username
TURN_PASSWORD=password

# Logging (Production: Less verbose)
LOG_LEVEL=WARNING
LOG_FILE=logs/lernsystemx.log

# Session Configuration
SESSION_TYPE=redis
SESSION_PERMANENT=False
SESSION_USE_SIGNER=True
SESSION_REDIS_URL=redis://localhost:6379/5

# Encryption
ENCRYPTION_KEY=CHANGE_THIS_TO_RANDOM_SALT
