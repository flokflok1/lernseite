# LernsystemX Backend - Production Environment Variables
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!

# ==========================================
# ENVIRONMENT
# ==========================================
FLASK_ENV=production
LSX_ENV=production
LSX_VERSION=1.0.0

# ==========================================
# SECURITY
# ==========================================
# CRITICAL: Change these to random, secure values!
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_JWT_SECRET
TOKEN_SALT=CHANGE_THIS_TO_RANDOM_SALT

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://lsx_user:SECURE_PASSWORD@localhost:5432/lernsystemx_prod

# Database Pool Configuration
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=60
DB_POOL_MAX_IDLE=300

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# CELERY (Task Queue)
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==========================================
# CORS (Cross-Origin Resource Sharing)
# ==========================================
# Add your frontend domain(s), comma-separated
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# GUNICORN
# ==========================================
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
GUNICORN_BIND=0.0.0.0:8000

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/lsx/backend.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==========================================
# RATE LIMITING
# ==========================================
RATELIMIT_STORAGE_URL=redis://localhost:6379/4
RATELIMIT_DEFAULT=100 per hour

# ==========================================
# SESSION
# ==========================================
SESSION_TYPE=redis
SESSION_REDIS_URL=redis://localhost:6379/5

# ==========================================
# SOCKETIO (WebSocket)
# ==========================================
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/3
SOCKETIO_CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ==========================================
# FILE UPLOADS
# ==========================================
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=/opt/lsx/backend/uploads
ALLOWED_EXTENSIONS=pdf,docx,pptx,jpg,jpeg,png,gif

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL=https://yourdomain.com

# ==========================================
# EMAIL (SMTP)
# ==========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ==========================================
# AI INTEGRATIONS
# ==========================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# DeepL (Translation)
DEEPL_API_KEY=your-deepl-api-key

# ==========================================
# PAYMENT (Stripe)
# ==========================================
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# PREMIUM MODEL
# ==========================================
PREMIUM_PRICE_MONTHLY=14.99
PREMIUM_PRICE_YEARLY=129.99
PREMIUM_TOKENS_MONTHLY=10000

# ==========================================
# TOKEN PRICING (EUR per package)
# ==========================================
TOKEN_PRICE_5K=1.99
TOKEN_PRICE_20K=6.99
TOKEN_PRICE_50K=14.99
TOKEN_PRICE_100K=24.99

# ==========================================
# JWT TOKEN EXPIRATION
# ==========================================
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ==========================================
# CACHE TTL (in seconds)
# ==========================================
CACHE_DEFAULT_TTL=600
CACHE_COURSE_TTL=3600
CACHE_CATEGORY_TTL=3600
CACHE_LEARNING_METHOD_TTL=3600
CACHE_ORGANISATION_TTL=300
CACHE_ANALYTICS_TTL=60

# ==========================================
# LIVEROOM (WebRTC)
# ==========================================
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password

# ==========================================
# BACKUP & RECOVERY
# ==========================================
BACKUP_DIR=/var/backups/lsx
BACKUP_RETENTION_DAYS=30
BACKUP_DB_NAME=lernsystemx_prod
BACKUP_DB_HOST=localhost
BACKUP_DB_PORT=5432
BACKUP_DB_USER=lsx_user
BACKUP_ENABLE_COMPRESSION=True
BACKUP_ENABLE_ENCRYPTION=False
# BACKUP_ENCRYPTION_KEY=CHANGE_THIS_IF_ENCRYPTION_ENABLED

# Optional: Remote Backup to S3/MinIO
BACKUP_REMOTE_ENABLED=False
# BACKUP_S3_BUCKET=lsx-backups
# BACKUP_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# BACKUP_S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
# BACKUP_S3_SECRET_KEY=YOUR_AWS_SECRET_KEY

# ==========================================
# MONITORING & ALERTING
# ==========================================
MONITORING_ENABLED=True
MONITORING_EXPORTER=prometheus
MONITORING_METRICS_PATH=/metrics
MONITORING_SAMPLE_RATE=1.0

# Error Tracking (Sentry - optional)
ERROR_TRACKING_ENABLED=False
# ERROR_TRACKING_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
ERROR_TRACKING_SAMPLE_RATE=1.0
ERROR_TRACKING_ENVIRONMENT=production

# ==========================================
# SECURITY (Phase 20)
# ==========================================

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGITS=True
PASSWORD_REQUIRE_SPECIAL=True

# Login Security & Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ACCOUNT_LOCKOUT_THRESHOLD=10

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_LOGIN=5 per minute
RATE_LIMIT_API=100 per minute
RATE_LIMIT_SENSITIVE=10 per minute

# Security Headers
SECURITY_HEADERS_ENABLED=True
HSTS_MAX_AGE=31536000

# Audit Logging
AUDIT_LOG_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=365

# ==========================================
# API GATEWAY (Phase 21)
# ==========================================

# Gateway Core Settings
API_GATEWAY_ENABLED=True
API_BASE_PATH=/api/v1
API_VERSION=1

# API Prefixes (Route Segmentation)
API_PUBLIC_PREFIX=/api/v1/public
API_APP_PREFIX=/api/v1
API_ADMIN_PREFIX=/api/v1/admin
API_ORG_PREFIX=/api/v1/organisations

# Gateway Logging & Analytics
API_GATEWAY_LOG_REQUESTS=True
API_GATEWAY_TRACK_ANALYTICS=True
API_GATEWAY_REQUEST_ID_HEADER=X-LSX-Request-ID

# Gateway Rate Limiting (per route group)
API_GATEWAY_RATE_LIMIT_DEFAULT=100 per minute
API_GATEWAY_RATE_LIMIT_ADMIN=200 per minute
API_GATEWAY_RATE_LIMIT_PUBLIC=10 per minute
API_GATEWAY_RATE_LIMIT_KI=30 per minute
API_GATEWAY_RATE_LIMIT_ANALYTICS=60 per minute
API_GATEWAY_RATE_LIMIT_LIVEROOM=100 per minute

# Request Validation
API_GATEWAY_MAX_BODY_SIZE=20971520
API_GATEWAY_VALIDATE_CONTENT_TYPE=True

# Multi-Tenant Domain Routing
API_GATEWAY_MULTI_TENANT_ENABLED=True
API_GATEWAY_DEFAULT_ORG_HEADER=X-LSX-Org-ID
API_GATEWAY_CLIENT_HEADER=X-LSX-Client

# ==========================================
# API VERSIONING & CHANGE MANAGEMENT (Phase 22)
# ==========================================
# Based on Dok 33 (Versioning-Change-Management.md)

# System Version (Semantic Versioning: MAJOR.MINOR.PATCH)
LSX_VERSION=1.0.0
LSX_ENV=production

# API Version Configuration
API_VERSION_CURRENT=1
API_VERSION_SUPPORTED=1
API_VERSION_DEFAULT=1

# API Version Headers
API_VERSION_HEADER=X-LSX-API-Version
API_SYSTEM_VERSION_HEADER=X-LSX-System-Version

# Deprecation Configuration
API_DEPRECATION_ENABLED=True
API_DEPRECATION_HEADER=X-LSX-Deprecated
API_DEPRECATION_DATE_HEADER=X-LSX-Deprecation-Date
API_SUNSET_DATE_HEADER=X-LSX-Sunset-Date
API_MIGRATION_GUIDE_HEADER=X-LSX-Migration-Guide
API_REPLACEMENT_HEADER=X-LSX-Replacement

# Deprecation Notice URL
API_DEPRECATION_NOTICE_URL=https://docs.lernsystemx.de/api/deprecation-notices

# Version Support Window (in months)
API_VERSION_SUPPORT_WINDOW=12
API_VERSION_DEPRECATION_WARNING=6

# Version Detection Strategy (url, header, both)
API_VERSION_DETECTION=url
API_VERSION_ALLOW_HEADER_OVERRIDE=False

# Breaking Change Protection
API_ENFORCE_VERSION_CHECK=True
API_REJECT_UNSUPPORTED_VERSIONS=True
