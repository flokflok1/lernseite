# LernsystemX Backend - Git Ignore Configuration
# Prevents committing sensitive data and build artifacts

# Environment Variables (CRITICAL - Contains API Keys & Secrets)
.env
.env.local
.env.*.local
*.env

# Python Cache & Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Flask
instance/
.webassets-cache

# Database
*.db
*.sqlite
*.sqlite3
*.db-journal

# Logs
logs/
*.log
*.log.*

# File Uploads
uploads/
temp_uploads/
*.pdf
*.docx
*.pptx

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Distribution / Packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Celery
celerybeat-schedule
celerybeat.pid

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# Secrets & Certificates
*.pem
*.key
*.cert
secrets/

# Backup files
*.bak
*.backup
*.old

# OS specific
Thumbs.db
.DS_Store

# ============================================
# CRITICAL: Storage & User Generated Content
# ============================================

# User uploads (AI jobs, course materials)
app/uploads/
storage/

# Media cache (TTS audio, generated content)
media_cache/

# ============================================
# CRITICAL: Credentials & Test Files
# ============================================

# Database credentials (NEVER commit!)
db_credentials.txt
*_credentials.txt
*.credentials

# Test files (development artifacts)
test_*.json
test_*.wav
test_*.mp3
test_*.pdf

# HAR files (contain sensitive request data)
*.har
