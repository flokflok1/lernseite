[Unit]
Description=LernsystemX Backup Cleanup Timer
Documentation=https://github.com/your-org/lernsystemx
Requires=lsx-backup-cleanup.service

[Timer]
# Run weekly on Sunday at 4:00 AM (after backup)
OnCalendar=Sun *-*-* 04:00:00

# If system was off, run cleanup after boot
Persistent=true

# Randomize start time by up to 10 minutes
RandomizedDelaySec=10min

[Install]
WantedBy=timers.target
