{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts",
    "build:typecheck": "vue-tsc -b -p config/tsconfig.json && vite build --config config/vite.config.ts",
    "typecheck": "vue-tsc --noEmit -p config/tsconfig.json",
    "preview": "vite preview --config config/vite.config.ts",
    "check": "node scripts/setup/check-setup.js",
    "test": "vitest --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts --watch",
    "test:coverage": "vitest --config config/vitest.config.ts --coverage",
    "test:ui": "vitest --config config/vitest.config.ts --ui",
    "migrate:baseline": "node scripts/compare-bundle-size.js --baseline",
    "migrate:check": "node scripts/compare-bundle-size.js --check",
    "migrate:report": "node scripts/compare-bundle-size.js --report",
    "validate:imports": "node scripts/validate-imports.js",
    "validate:imports:fix": "node scripts/validate-imports.js --fix",
    "generate:barrels": "node scripts/generate-barrels.js",
    "codemod:imports": "npx jscodeshift -t scripts/transforms/update-imports.js src/ --dry",
    "codemod:imports:apply": "npx jscodeshift -t scripts/transforms/update-imports.js src/",
    "codemod:deprecations": "npx jscodeshift -t scripts/transforms/add-deprecation-notices.js src/ --dry",
    "codemod:deprecations:apply": "npx jscodeshift -t scripts/transforms/add-deprecation-notices.js src/",
    "percy:baseline": "npm run build && percy exec -- npm run preview",
    "percy:test": "percy exec -- npm run preview",
    "percy:approval": "echo '🎨 Review visual diffs at: https://percy.io/[project-slug]'"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@pixiv/three-vrm": "^3.4.4",
    "@types/three": "^0.181.0",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "dompurify": "^3.3.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.1",
    "three": "^0.181.2",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@percy/cli": "^1.1.42",
    "@percy/cli-exec": "^1.1.42",
    "@testing-library/vue": "^8.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.22",
    "jscodeshift": "^0.14.0",
    "jsdom": "^23.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.1.3"
  }
}
